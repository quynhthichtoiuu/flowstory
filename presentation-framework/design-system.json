{
  "name": "FlowStory Workshop Design System",
  "version": "1.0.0",
  "description": "Slowly/Ando Style - Soft cream, warm muted yellow with Vietnamese typography",

  "primitives": {
    "colors": {
      "dark": "#1a1a1a",
      "light": "#fffcf7",
      "mid": "#9a9590",
      "light-gray": "#f7f3ed",
      "gold": "#d4a000",
      "gold-dark": "#b8860b",
      "gold-light": "#f5d668",
      "blue": "#6a9bcc",
      "green": "#788c5d",
      "red": "#c07a6e",
      "yellow": "#d4a84b",
      "purple": "#a07fb5",
      "teal": "#5a9b94"
    },
    "typography": {
      "font-head": "\"Be Vietnam Pro\", \system-ui, sans-serif",
      "font-body": "\"Lora\", \"Be Vietnam Pro\", \"Noto Serif Display\", Georgia, serif",
      "font-mono": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "spacing": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px"
    },
    "radius": {
      "sm": "4px",
      "md": "10px",
      "default": "14px",
      "lg": "20px",
      "full": "9999px"
    },
    "layout": {
      "max-width": "1240px",
      "max-narrow": "780px"
    },
    "shadows": {
      "sm": "0 1px 2px rgba(0,0,0,0.05)",
      "md": "0 4px 12px rgba(0,0,0,0.08)",
      "lg": "0 8px 24px rgba(0,0,0,0.12)",
      "drawer": "-4px 0 24px rgba(0,0,0,0.15)"
    },
    "transitions": {
      "ease-out": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "ease-smooth": "cubic-bezier(0.4, 0, 0.2, 1)",
      "duration-fast": "150ms",
      "duration-normal": "250ms",
      "duration-slow": "400ms"
    },
    "opacity": {
      "muted": "0.75",
      "subtle": "0.55",
      "disabled": "0.4"
    }
  },

  "semantic": {
    "colors": {
      "background": "var(--light)",
      "background-dark": "var(--dark)",
      "text-primary": "var(--dark)",
      "text-secondary": "var(--mid)",
      "text-inverse": "var(--light)",
      "accent": "var(--gold)",
      "success": "var(--green)",
      "info": "var(--blue)",
      "warning": "var(--yellow)",
      "error": "var(--red)",
      "border": "var(--light-gray)"
    },
    "typography": {
      "heading": "var(--font-head)",
      "body": "var(--font-body)",
      "code": "var(--font-mono)"
    }
  },

  "components": {
    "slide": {
      "padding": "72px 5vw",
      "min-height": "100vh",
      "border-bottom": "1px solid var(--light-gray)"
    },
    "card": {
      "background": "#fff",
      "border": "1px solid var(--light-gray)",
      "border-radius": "12px",
      "padding": "20px 22px"
    },
    "terminal": {
      "background": "#0d0d0c",
      "color": "#e8e6dc",
      "border-radius": "12px",
      "padding": "22px 26px",
      "font-size": "14px"
    },
    "button": {
      "padding": "13px 22px",
      "border-radius": "var(--radius)",
      "font-family": "var(--font-head)",
      "font-size": "14.5px"
    },
    "kicker": {
      "font-family": "var(--font-head)",
      "font-size": "12px",
      "font-weight": "600",
      "letter-spacing": "0.12em",
      "text-transform": "uppercase",
      "color": "var(--gold)"
    }
  },

  "typography-scale": {
    "hero-h1": "clamp(2.8rem, 6vw, 5rem)",
    "h1": "clamp(2.2rem, 4.6vw, 3.8rem)",
    "h2": "clamp(1.4rem, 2.4vw, 1.9rem)",
    "h3": "1.25rem",
    "h4": "1.1rem",
    "body": "18px",
    "body-small": "16px",
    "caption": "14px",
    "micro": "14px"
  },

  "terminal-syntax": {
    "prompt": "var(--gold)",
    "user": "#9ab98a",
    "command": "#8ea5c0",
    "warning": "var(--yellow)",
    "error": "#e5a79b",
    "success": "#a8c48d",
    "dim": "#7a7870",
    "bold": "#fff"
  },

  "google-fonts": "https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap&subset=vietnamese,latin,latin-ext"
}
